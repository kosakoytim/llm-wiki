{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "preference",
  "title": "Preference",
  "description": "Communication and behavioral rules the agent must follow.",
  "type": "object",
  "required": ["title", "type"],
  "properties": {
    "title": { "type": "string" },
    "type": { "type": "string", "const": "preference" },
    "summary": { "type": "string" },
    "tldr": { "type": "string", "description": "One-sentence rule the agent must remember" },
    "status": { "type": "string", "enum": ["active", "superseded", "draft"], "default": "active" },
    "last_updated": { "type": "string", "description": "ISO 8601 date" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "superseded_by": { "type": "string" },
    "read_when": { "type": "array", "items": { "type": "string" }, "description": "Situations when this preference should be applied" },
    "applies_to": { "type": "string", "description": "Slug of identity, or 'global'" },
    "category": { "type": "string", "description": "e.g. chat_behavior, scheduling, language, formatting, tone" },
    "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0, "default": 0.8 },
    "last_read": { "type": "string", "description": "ISO 8601 date" },
    "importance_score": { "type": "number", "minimum": 0.0, "maximum": 1.0, "default": 0.8 },
    "read_count": { "type": "integer", "default": 0 },
    "claims": {
      "type": "array",
      "description": "Individual preference rules with confidence",
      "items": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
          "source": { "type": "string" },
          "section": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "concepts": { "type": "array", "items": { "type": "string" } },
    "sources": { "type": "array", "items": { "type": "string" } }
  },
  "x-wiki-types": { "preference": "Communication and behavioral rules the agent must follow" },
  "x-graph-edges": {
    "applies_to": { "relation": "applies-to", "direction": "outgoing", "target_types": ["identity"] },
    "concepts": { "relation": "relates-to", "direction": "outgoing" },
    "sources": { "relation": "evidenced-by", "direction": "outgoing" },
    "superseded_by": { "relation": "superseded-by", "direction": "outgoing" }
  },
  "additionalProperties": true
}
