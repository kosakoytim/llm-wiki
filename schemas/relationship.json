{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "relationship",
  "title": "Relationship",
  "description": "How two entities relate to each other.",
  "type": "object",
  "required": ["title", "type", "entity_a", "entity_b"],
  "properties": {
    "title": { "type": "string", "description": "e.g. 'Timothy <> Arline'" },
    "type": { "type": "string", "const": "relationship" },
    "summary": { "type": "string" },
    "tldr": { "type": "string", "description": "One-sentence essence of the dynamic" },
    "status": { "type": "string", "enum": ["active", "inactive", "ended"], "default": "active" },
    "last_updated": { "type": "string", "description": "ISO 8601 date" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "superseded_by": { "type": "string" },
    "read_when": { "type": "array", "items": { "type": "string" }, "description": "Situations when this page should be retrieved" },
    "entity_a": { "type": "string", "description": "Slug of first identity page" },
    "entity_b": { "type": "string", "description": "Slug of second identity page" },
    "relation_type": { "type": "string", "description": "e.g. close_friend, partner, colleague, manages, family" },
    "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0, "default": 0.7 },
    "last_read": { "type": "string", "description": "ISO 8601 date" },
    "importance_score": { "type": "number", "minimum": 0.0, "maximum": 1.0, "default": 0.7 },
    "read_count": { "type": "integer", "default": 0 },
    "claims": {
      "type": "array",
      "description": "Structured facts about this relationship",
      "items": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
          "source": { "type": "string" },
          "section": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "concepts": { "type": "array", "items": { "type": "string" } },
    "sources": { "type": "array", "items": { "type": "string" } }
  },
  "x-wiki-types": { "relationship": "How two entities relate to each other" },
  "x-graph-edges": {
    "entity_a": { "relation": "involves", "direction": "outgoing", "target_types": ["identity"] },
    "entity_b": { "relation": "involves", "direction": "outgoing", "target_types": ["identity"] },
    "concepts": { "relation": "relates-to", "direction": "outgoing" },
    "sources": { "relation": "evidenced-by", "direction": "outgoing" },
    "superseded_by": { "relation": "superseded-by", "direction": "outgoing" }
  },
  "additionalProperties": true
}
