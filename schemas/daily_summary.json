{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "daily_summary",
  "title": "Daily Summary",
  "description": "Synthesized digest of what happened on a specific day.",
  "type": "object",
  "required": ["title", "type", "date"],
  "properties": {
    "title": { "type": "string", "description": "e.g. '2026-05-11 Daily Summary'" },
    "type": { "type": "string", "const": "daily_summary" },
    "summary": { "type": "string", "description": "One-line highlight of the day" },
    "tldr": { "type": "string", "description": "One-sentence of the most important thing that happened" },
    "status": { "type": "string", "enum": ["active", "archived"], "default": "active" },
    "last_updated": { "type": "string", "description": "ISO 8601 date" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "superseded_by": { "type": "string", "description": "rag:// reference when archived" },
    "read_when": { "type": "array", "items": { "type": "string" }, "description": "Situations when this day's summary is relevant" },
    "date": { "type": "string", "description": "The date this covers (WIB, YYYY-MM-DD)" },
    "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0, "default": 1.0 },
    "last_read": { "type": "string", "description": "ISO 8601 date" },
    "importance_score": { "type": "number", "minimum": 0.0, "maximum": 1.0, "default": 0.5 },
    "read_count": { "type": "integer", "default": 0 },
    "claims": {
      "type": "array",
      "description": "Key events or decisions from this day",
      "items": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
          "source": { "type": "string" },
          "section": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "concepts": { "type": "array", "items": { "type": "string" } },
    "sources": { "type": "array", "items": { "type": "string" } }
  },
  "x-wiki-types": { "daily_summary": "Synthesized digest of what happened on a specific day" },
  "x-graph-edges": {
    "concepts": { "relation": "references", "direction": "outgoing" },
    "sources": { "relation": "evidenced-by", "direction": "outgoing" },
    "superseded_by": { "relation": "superseded-by", "direction": "outgoing" }
  },
  "additionalProperties": true
}
