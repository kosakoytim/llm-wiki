{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "task_context",
  "title": "Task Context",
  "description": "Background understanding behind an active task or recurring job.",
  "type": "object",
  "required": ["title", "type"],
  "properties": {
    "title": { "type": "string" },
    "type": { "type": "string", "const": "task_context" },
    "summary": { "type": "string" },
    "tldr": { "type": "string", "description": "One-sentence of why this task exists" },
    "status": { "type": "string", "enum": ["active", "completed", "cancelled"], "default": "active" },
    "last_updated": { "type": "string", "description": "ISO 8601 date" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "superseded_by": { "type": "string" },
    "read_when": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Situations when this task context is relevant"
    },
    "task_id": { "type": "string", "description": "Reference to Supabase task id" },
    "requester": { "type": "string", "description": "Slug of identity who requested this" },
    "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0, "default": 0.8 },
    "last_read": { "type": "string", "description": "ISO 8601 date" },
    "importance_score": { "type": "number", "minimum": 0.0, "maximum": 1.0, "default": 0.7 },
    "read_count": { "type": "integer", "default": 0 },
    "claims": {
      "type": "array",
      "description": "Background facts explaining this task",
      "items": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
          "source": { "type": "string" },
          "section": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "concepts": { "type": "array", "items": { "type": "string" } },
    "sources": { "type": "array", "items": { "type": "string" } }
  },
  "x-wiki-types": {
    "task_context": "Background understanding behind an active task or recurring job"
  },
  "x-graph-edges": {
    "requester": { "relation": "requested-by", "direction": "outgoing", "target_types": ["identity"] },
    "concepts": { "relation": "relates-to", "direction": "outgoing" },
    "sources": { "relation": "evidenced-by", "direction": "outgoing" },
    "superseded_by": { "relation": "superseded-by", "direction": "outgoing" }
  },
  "additionalProperties": true
}
