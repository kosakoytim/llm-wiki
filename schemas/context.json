{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "context",
  "title": "Context",
  "description": "Background information that frames ongoing situations and decisions.",
  "type": "object",
  "required": ["title", "type"],
  "properties": {
    "title": { "type": "string" },
    "type": { "type": "string", "const": "context" },
    "summary": { "type": "string" },
    "tldr": { "type": "string", "description": "One-sentence framing of the situation" },
    "status": { "type": "string", "enum": ["active", "outdated", "archived"], "default": "active" },
    "last_updated": { "type": "string", "description": "ISO 8601 date" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "superseded_by": { "type": "string" },
    "read_when": { "type": "array", "items": { "type": "string" }, "description": "Situations when this background context is relevant" },
    "applies_to": { "type": "string", "description": "Slug of identity, project, or situation this frames" },
    "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0, "default": 0.75 },
    "last_read": { "type": "string", "description": "ISO 8601 date" },
    "importance_score": { "type": "number", "minimum": 0.0, "maximum": 1.0, "default": 0.75 },
    "read_count": { "type": "integer", "default": 0 },
    "claims": {
      "type": "array",
      "description": "Specific contextual facts",
      "items": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
          "source": { "type": "string" },
          "section": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "concepts": { "type": "array", "items": { "type": "string" } },
    "sources": { "type": "array", "items": { "type": "string" } }
  },
  "x-wiki-types": { "context": "Background information that frames ongoing situations and decisions" },
  "x-graph-edges": {
    "applies_to": { "relation": "frames", "direction": "outgoing" },
    "concepts": { "relation": "relates-to", "direction": "outgoing" },
    "sources": { "relation": "evidenced-by", "direction": "outgoing" },
    "superseded_by": { "relation": "superseded-by", "direction": "outgoing" }
  },
  "additionalProperties": true
}
